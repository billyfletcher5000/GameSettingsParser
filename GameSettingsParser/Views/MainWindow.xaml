<Window x:Class="GameSettingsParser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:GameSettingsParser.ViewModels"
        xmlns:controls="clr-namespace:GameSettingsParser.Controls"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        d:DataContext="{d:DesignInstance Type=viewmodels:MainWindowViewModel, IsDesignTimeCreatable=False}"
        mc:Ignorable="d"
        Title="{Binding Path=WindowTitle}">
    
    <b:Interaction.Triggers>
        <b:EventTrigger EventName="Closing">
            <b:InvokeCommandAction Command="{Binding ClosingWindowCommand}" />
        </b:EventTrigger>
    </b:Interaction.Triggers>
    
    <Window.InputBindings>
        <KeyBinding Command="{Binding Path=FileNewCommand}" Gesture="Ctrl+N" />
        <KeyBinding Command="{Binding Path=FileOpenCommand}" Gesture="Ctrl+O" />
        <KeyBinding Command="{Binding Path=FileSaveCommand}" Gesture="Ctrl+S" />
        <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding Path=FileSaveAsCommand}"/>
    </Window.InputBindings>
    
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New" Command="{Binding Path=FileNewCommand}" InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Open" Command="{Binding Path=FileOpenCommand}" InputGestureText="Ctrl+O"/>
                <MenuItem Header="_Save" Command="{Binding Path=FileSaveCommand}" InputGestureText="Ctrl+S"/>
                <MenuItem Header="Save _As" Command="{Binding Path=FileSaveAsCommand}" InputGestureText="Ctrl+Shift+S"/>
                <MenuItem Header="_Export Project" Command="{Binding Path=FileExportCommand}"/>
                <MenuItem Header="_Exit" Command="{Binding Path=FileExitCommand}"/>
            </MenuItem>
        </Menu>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>
            
            <Grid Grid.Row="0" MinHeight="400" MinWidth="720" Margin="10, 10" Background="LightGray">
                <controls:MarkupCanvas ImageInstance="{Binding Path=SelectedImageInstance}" SelectedMarkupType="{Binding SelectedMarkupType}"/>
            </Grid>
            <StackPanel Grid.Row="1" Orientation="Vertical">
                <StackPanel Orientation="Horizontal">
                    <GroupBox Margin="10, 0, 10, 10">
                        <GroupBox.Header>
                            <Label>Image Control</Label>
                        </GroupBox.Header>
                        <StackPanel Orientation="Horizontal">
                            <Button Width="Auto" Height="30" Margin="2, 0" Command="{Binding Path=AddImageCommand}">
                                <TextBlock Text="+" Margin="6, 0"/>
                            </Button>
                            <Button Width="Auto" Height="30" Margin="2, 0" Command="{Binding Path=RemoveImageCommand}">
                                <TextBlock Text="-" Margin="8, 0"/>
                            </Button>
                            <Button Width="Auto" Height="30" Margin="2, 0" Command="{Binding Path=GoToPreviousImageCommand}">
                                <TextBlock Text="&lt;" Margin="10, 0"/>
                            </Button>
                            <ComboBox MinWidth="200" Margin="2, 0" 
                                      ItemsSource="{Binding Path=Images}" 
                                      SelectedItem="{Binding Path=SelectedImage, Mode=TwoWay}" 
                                      />
                            <Button Width="Auto" Height="30" Margin="2, 0" Command="{Binding Path=GoToNextImageCommand}">
                                <TextBlock Text="&gt;" Margin="10, 0"/>
                            </Button>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Margin="10, 0, 10, 10">
                        <GroupBox.Header>
                            <Label>Markup Control</Label>
                        </GroupBox.Header>
                        <StackPanel Orientation="Horizontal">
                            <Button Width="Auto" Height="30" Margin="2, 0" Command="{Binding Path=AddMarkupTypeCommand}">
                                <TextBlock Text="+" Margin="6, 0"/>
                            </Button>
                            <Button Width="Auto" Height="30" Margin="2, 0" Command="{Binding Path=RemoveMarkupTypeCommand}">
                                <TextBlock Text="-" Margin="8, 0"/>
                            </Button>
                            <ComboBox MinWidth="200" Margin="2, 0" ItemsSource="{Binding Path=MarkupTypes}" SelectedItem="{Binding Path=SelectedMarkupType, Mode=TwoWay}" />
                            <Button Width="Auto" Height="30" Margin="2, 0" Command="{Binding Path=EditMarkupTypeCommand}">
                                <TextBlock Text="Edit" Margin="8, 0"/>
                            </Button>
                            <Button Width="Auto" Height="30" Margin="2, 0" Command="{Binding Path=ClearTypeInstancesCommand}">
                                <TextBlock Text="Clear Type" Margin="8, 0"/>
                            </Button>
                            <Button Width="Auto" Height="30" Margin="2, 0" Command="{Binding Path=ClearAllInstancesCommand}">
                                <TextBlock Text="Clear All" Margin="8, 0"/>
                            </Button>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Margin="10, 0, 10, 10">
                        <GroupBox.Header>
                            <Label>Parsing</Label>
                        </GroupBox.Header>
                        <StackPanel Orientation="Horizontal">
                            <Button Width="Auto" Height="30" Margin="2, 0" Command="{Binding Path=ParseToFileCommand}">
                                <TextBlock Text="Parse To File" Margin="8, 0"/>
                            </Button>
                            <Button Width="Auto" Height="30" Margin="2, 0" Command="{Binding Path=ParseToClipboardCommand}">
                                <TextBlock Text="Parse To Clipboard" Margin="8, 0"/>
                            </Button>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <GroupBox Margin="10, 0, 10, 10">
                        <GroupBox.Header>
                            <Label>Fine Control</Label>
                        </GroupBox.Header>
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Orientation="Horizontal" Margin="5, 0">
                                <StackPanel.ToolTip>
                                    The number of pixels between words for them to be considered part of the same block of text, tweak if you find words missing from titles. Only applies to dynamic markup types.
                                </StackPanel.ToolTip>
                                <Label>
                                    Space Distance (px):
                                </Label>
                                <xctk:IntegerUpDown Height="25" Width="80" Value="{Binding Path=WordGapThreshold}" Minimum="-1" Increment="1" />
                            </StackPanel>
                            
                            <StackPanel Orientation="Horizontal" Margin="5, 0">
                                <StackPanel.ToolTip>
                                    The minimum confidence (0.0-1.0) the text comparison service must achieve to consider a dynamic markdown type as the most likely result,
                                    leave at 0.0 unless you are using a comparison mode you really understand!
                                </StackPanel.ToolTip>
                                <Label>
                                    Minimum Comparison Confidence:
                                </Label>
                                <xctk:DoubleUpDown Height="25" Width="80" Value="{Binding Path=MinimumDynamicComparisonConfidence}" Minimum="0.0" Maximum="1.0" Increment="0.01" />
                            </StackPanel>
                        </StackPanel>
                        
                    </GroupBox>
                </StackPanel>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>