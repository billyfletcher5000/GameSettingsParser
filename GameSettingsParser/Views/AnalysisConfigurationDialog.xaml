<Window x:Class="GameSettingsParser.Views.AnalysisConfigurationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:GameSettingsParser.Views"
        xmlns:global="clr-namespace:GameSettingsParser"
        xmlns:mvvm="http://prismlibrary.com/"
        mvvm:ViewModelLocator.AutoWireViewModel="False"
        mc:Ignorable="d"
        Title="AnalysisConfigurationControl" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.Resources>
            <Style TargetType="{x:Type Button}">
                <Setter Property="Width" Value="70" />
                <Setter Property="Height" Value="25" />
                <Setter Property="Margin" Value="5,0,0,0" />
            </Style>
        </Grid.Resources>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TabControl Grid.Row="0">
            <TabItem Header="General">
                
            </TabItem>
            
            <TabItem Header="Text Comparison">
                <ContentControl mvvm:RegionManager.RegionName="{x:Static global:RegionNames.AnalysisConfigurationTextConfiguration}" Margin="5"/>
            </TabItem>
        </TabControl>
        
        <!-- Accept or Cancel -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0, 10, 0, 4">
            <Button Click="OkButton_OnClick" IsDefault="True">OK</Button>
            <Button Click="CancelButton_OnClick" IsCancel="True">Cancel</Button>
        </StackPanel>
    </Grid>
</Window>
