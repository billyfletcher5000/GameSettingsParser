<Window x:Class="GameSettingsParser.Views.Configuration.ConfigurationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:models="clr-namespace:GameSettingsParser.Model.Configuration"
        xmlns:viewModels="clr-namespace:GameSettingsParser.ViewModels.Configuration"
        xmlns:mvvm="http://prismlibrary.com/"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        mvvm:ViewModelLocator.AutoWireViewModel="False"
        d:DataContext="{d:DesignInstance Type=viewModels:ConfigurationDialogViewModel, IsDesignTimeCreatable=False}"
        mc:Ignorable="d"
        Title="ConfigurationDialog" Height="450" Width="800">
    <Grid>
        <Grid.Resources>
            <!-- Default settings for controls -->
            <Style TargetType="{x:Type Label}">
                <Setter Property="Margin" Value="0,3,5,5" />
                <Setter Property="Padding" Value="0,0,0,5" />
            </Style>
            <Style TargetType="{x:Type TextBox}">
                <Setter Property="Margin" Value="0,0,0,5" />
            </Style>
            <Style TargetType="{x:Type Button}">
                <Setter Property="Width" Value="70" />
                <Setter Property="Height" Value="25" />
                <Setter Property="Margin" Value="5,0,0,0" />
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <Grid Grid.Column="0" 
              HorizontalAlignment="Stretch" 
              VerticalAlignment="Stretch" Background="LightGray">
            <TreeView Margin="2" ItemsSource="{Binding Sections}">
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="SelectedItemChanged">
                        <b:InvokeCommandAction Command="{Binding OnTreeViewSelectionChangedCommand}"
                                               CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=TreeView}}" />
                    </b:EventTrigger>
                </b:Interaction.Triggers>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate DataType="{x:Type viewModels:ConfigurationSectionViewModel}" ItemsSource="{Binding Configurations}">
                        <Label Content="{Binding DisplayName}" />
                        <HierarchicalDataTemplate DataType="{x:Type models:IConfigurationModel}">
                            <Label Content="{Binding DisplayName}" />
                        </HierarchicalDataTemplate>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Grid>
        <GridSplitter Grid.Row="0" Grid.Column="1" 
                      HorizontalAlignment="Stretch" 
                      VerticalAlignment="Center"  />
        <Grid Grid.Row="0" Grid.Column="2"
              HorizontalAlignment="Stretch" 
              VerticalAlignment="Stretch" Background="LightGray">
            <ContentPresenter Content="{Binding SelectedConfiguration}"></ContentPresenter>
        </Grid>
        
        <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0, 10, 0, 4">
            <Button Click="OkButton_OnClick" IsDefault="True">OK</Button>
            <Button Click="CancelButton_OnClick" IsCancel="True">Cancel</Button>
            <Button Click="ApplyButton_OnClick">Apply</Button>
        </StackPanel>
    </Grid>
</Window>
