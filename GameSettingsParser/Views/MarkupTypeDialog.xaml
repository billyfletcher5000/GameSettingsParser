<Window x:Class="GameSettingsParser.Views.MarkupTypeDialog"
        x:Name="MarkupTypeDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:GameSettingsParser.Converters"
        MinHeight="130"
        MinWidth="300"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner" 
        FocusManager.FocusedElement="{Binding ElementName=NameBox}">
    
    <Window.Resources>
        <converters:ColorToBrushConverter x:Key="ColorToBrushConverter" />
    </Window.Resources>

    
    <Grid Margin="10">
        <Grid.Resources>
            <!-- Default settings for controls -->
            <Style TargetType="{x:Type Label}">
                <Setter Property="Margin" Value="0,3,5,5" />
                <Setter Property="Padding" Value="0,0,0,5" />
            </Style>
            <Style TargetType="{x:Type TextBox}">
                <Setter Property="Margin" Value="0,0,0,5" />
            </Style>
            <Style TargetType="{x:Type Button}">
                <Setter Property="Width" Value="70" />
                <Setter Property="Height" Value="25" />
                <Setter Property="Margin" Value="5,0,0,0" />
            </Style>
        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <!-- Left,Top,Right,Bottom margins-->
        <Label Grid.Column="0" Grid.Row="0">Name:</Label>
        <TextBox Grid.Column="1" Grid.Row="0" Name="NameBox" Text="{Binding ElementName=MarkupTypeDialogWindow, Path=TypeName, Mode=TwoWay}"/>

        <Label Grid.Column="0" Grid.Row="1">Color:</Label>
        <ComboBox Grid.Column="1" Grid.Row="1"
                  ItemsSource="{Binding ElementName=MarkupTypeDialogWindow, Path=ColorOptions}"
                  SelectedItem="{Binding ElementName=MarkupTypeDialogWindow, Path=TypeColor, Mode=TwoWay}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <Rectangle Fill="{Binding Color, Converter={StaticResource ColorToBrushConverter}}" Height="10" Width="10" Margin="2, 0, 6, 0"/>
                        <TextBlock Text="{Binding Name}"/>
                    </StackPanel>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        
        <Label Grid.Column="0" Grid.Row="2">Dynamic:</Label>
        <CheckBox Grid.Column="1" Grid.Row="2" VerticalAlignment="Center" IsChecked="{Binding ElementName=MarkupTypeDialogWindow, Path=IsDynamic, Mode=TwoWay}" />

        <!-- Accept or Cancel -->
        <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Click="OkButton_OnClick" IsDefault="True">OK</Button>
            <Button Click="CancelButton_OnClick" IsCancel="True">Cancel</Button>
        </StackPanel>
    </Grid >
</Window>

