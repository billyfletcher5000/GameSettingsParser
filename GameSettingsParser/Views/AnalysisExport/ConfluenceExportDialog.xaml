<Window x:Class="GameSettingsParser.Views.AnalysisExport.ConfluenceExportDialog"
        x:Name="ConfluenceExportDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:GameSettingsParser.Converters"
        xmlns:viewModels="clr-namespace:GameSettingsParser.ViewModels"
        xmlns:mvvm="http://prismlibrary.com/"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        MinHeight="50"
        MinWidth="350"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner" 
        mvvm:ViewModelLocator.AutoWireViewModel="False"
        d:DataContext="{d:DesignInstance Type=viewModels:ConfluenceExportDialogViewModel, IsDesignTimeCreatable=False}"
        mc:Ignorable="d"
        FocusManager.FocusedElement="{Binding ElementName=NameBox}">
    
    <Window.Resources>
        <converters:ColorToBrushConverter x:Key="ColorToBrushConverter" />
    </Window.Resources>

    <!-- TODO: Stop using Grid columns and rows, it's horrible to maintain and there has to be a better way -->
    <Grid Margin="10">
        <Grid.Resources>
            <!-- Default settings for controls -->
            <Style TargetType="{x:Type Label}">
                <Setter Property="Margin" Value="0,3,5,5" />
                <Setter Property="Padding" Value="0,0,0,5" />
            </Style>
            <Style TargetType="{x:Type TextBox}">
                <Setter Property="Margin" Value="0,0,0,5" />
            </Style>
            <Style TargetType="{x:Type Button}">
                <Setter Property="Width" Value="70" />
                <Setter Property="Height" Value="25" />
                <Setter Property="Margin" Value="5,0,0,0" />
            </Style>
        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <Label Grid.Column="0" Grid.Row="0">Site:</Label>
        <ComboBox Grid.Column="1" Grid.Row="0" Margin="0, 0, 0, 8"
                  ItemsSource="{Binding Path=SiteOptions}"
                  SelectedItem="{Binding Path=Site, Mode=TwoWay}"/>

        <Label Grid.Column="0" Grid.Row="1">Space:</Label>
        <ComboBox Grid.Column="1" Grid.Row="1" Margin="0, 0, 0, 8"
                  ItemsSource="{Binding Path=SpaceOptions}"
                  SelectedItem="{Binding Path=Space, Mode=TwoWay}"/>
        
        <Label Grid.Column="0" Grid.Row="2">Page:</Label>
        <ComboBox Grid.Column="1" Grid.Row="2" Margin="0, 0, 0, 8"
                  ItemsSource="{Binding Path=PageOptions}"
                  SelectedItem="{Binding Path=Page, Mode=TwoWay}"/>
        
        <Label Grid.Column="0" Grid.Row="3">Mode:</Label>
        <ComboBox Grid.Column="1" Grid.Row="3" Margin="0, 0, 0, 8"
                  ItemsSource="{Binding Path=ModeOptions}"
                  SelectedItem="{Binding Path=Mode, Mode=TwoWay}"/>

        <!-- Accept or Cancel -->
        <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0, 10, 0, 4">
            <Button Click="OkButton_OnClick" IsDefault="True" IsEnabled="{Binding Path=IsOkEnabled}">OK</Button>
            <Button Click="CancelButton_OnClick" IsCancel="True">Cancel</Button>
        </StackPanel>
    </Grid >
</Window>

